! ── HIGH DENSITY LOADS (updated each timestep by simulation) ──
New Load.EVLoad  phases=3 bus1=Bus18 kv=12.66 kW=100   kvar=15   model=1
New Load.AILoad  phases=3 bus1=Bus33 kv=12.66 kW=100   kvar=10   model=1

! ── SOLUTION SETTINGS ──
Set VoltageBases=[12.66]
CalcVoltageBases
Set Mode=Snapshot
Set ControlMode=Static
Set MaxIter=100

Solve
